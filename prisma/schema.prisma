generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  password     String?
  role         UserRole    @default(PRODUCER)
  avatarUrl    String?
  telefono     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  fincas       Finca[]
  compradores  Comprador[]
  chatMessages ChatMessage[]
  preferences  UserPreferences?

  @@map("users")
}

enum UserRole {
  PRODUCER
  ADVISOR
  BUYER
  ADMIN
}

// ─── FARMS / FINCAS ───────────────────────────────────────────────────────────

model Finca {
  id           String   @id @default(cuid())
  nombre       String
  municipio    String
  departamento String
  altitud      Float?
  lat          Float?
  lng          Float?
  areaTotal    Float?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lotes        Lote[]

  @@map("fincas")
}

// ─── LOTS / LOTES ─────────────────────────────────────────────────────────────

model Lote {
  id        String   @id @default(cuid())
  nombre    String
  fincaId   String
  finca     Finca    @relation(fields: [fincaId], references: [id], onDelete: Cascade)
  areaHa    Float
  pendiente Float?
  altitud   Float?
  geoJson   Json?
  lat       Float?
  lng       Float?
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cultivos  Cultivo[]
  jornales  Jornal[]

  @@map("lotes")
}

// ─── CROP SPECIES CATALOG / ESPECIES DE CULTIVO (PARAMÉTRICO) ─────────────────
// Tabla de configuración que define las propiedades de cada tipo de cultivo.
// Permite soportar múltiples cultivos (café, cacao, cítricos) sin modificar enums.

model EspecieCultivo {
  id              String   @id @default(cuid())
  slug            String   @unique             // "aguacate-hass", "cafe-caturra", "cacao-ccu51"
  nombre          String                       // "Aguacate Hass"
  familia         String?                      // "Lauraceae", "Rubiaceae"
  
  // Etapas fenológicas como JSON array — reemplaza el enum para cultivos nuevos
  // Ej: ["PREPARACION","SIEMBRA","ESTABLECIMIENTO","CRECIMIENTO","PRODUCCION","COSECHA"]
  etapas          Json                         // string[]
  
  // Tipos de registro válidos para esta especie
  // Ej: ["RIEGO","FERTILIZACION","PODA","COSECHA","DESPULPADO","SECADO"]
  tiposRegistro   Json                         // string[]
  
  // Umbrales climáticos específicos del cultivo
  umbralHelada    Float?                       // °C mínimo antes de daño
  umbralCalor     Float?                       // °C máximo antes de estrés
  lluviaMaxMm     Float?                       // mm/día para alerta
  vientoMaxKmh    Float?                       // km/h para alerta
  
  // Ciclo productivo
  cicloMesesPrimeraCosecha Int?                // Meses desde siembra hasta primera cosecha
  produccionKgArbolAnual   Float?             // kg promedio por árbol/año en plena producción
  
  // Rango altitudinal óptimo (msnm)
  altitudMin      Int?
  altitudMax      Int?
  
  // Condiciones climáticas óptimas
  tempOptMin      Float?                       // °C mínimo óptimo
  tempOptMax      Float?                       // °C máximo óptimo
  precipAnualMin  Float?                       // mm/año mínimo
  precipAnualMax  Float?                       // mm/año máximo
  
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cultivos        Cultivo[]

  @@map("especies_cultivo")
}

// ─── CROPS / CULTIVOS ─────────────────────────────────────────────────────────

model Cultivo {
  id              String        @id @default(cuid())
  loteId          String
  lote            Lote          @relation(fields: [loteId], references: [id], onDelete: Cascade)
  especie         String        @default("Aguacate")
  variedad        String        @default("Hass")
  especieId       String?
  especieCultivo  EspecieCultivo? @relation(fields: [especieId], references: [id])
  fechaSiembra    DateTime?
  cantidadPlantas Int?
  densidadHa      Int?
  etapa           EtapaCultivo  @default(PREPARACION)
  estado          EstadoCultivo @default(ACTIVO)
  notas           String?
  portainjerto    String?
  proveedorMaterial String?
  sistemaSiembra  String?
  distanciaSiembra String?
  observaciones   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  registros       RegistroCultivo[]
  gastos          Gasto[]
  ingresos        Ingreso[]
  jornales        Jornal[]

  @@map("cultivos")
}

enum EtapaCultivo {
  PREPARACION
  SIEMBRA
  ESTABLECIMIENTO
  CRECIMIENTO
  PRODUCCION
  COSECHA
}

enum EstadoCultivo {
  ACTIVO
  PAUSADO
  FINALIZADO
}

// ─── CROP LOGS / REGISTROS ────────────────────────────────────────────────────

model RegistroCultivo {
  id          String       @id @default(cuid())
  cultivoId   String
  cultivo     Cultivo      @relation(fields: [cultivoId], references: [id], onDelete: Cascade)
  tipo        TipoRegistro
  descripcion String
  fecha       DateTime     @default(now())
  imagenes    String[]
  datos       Json?
  createdAt   DateTime     @default(now())

  @@map("registros_cultivo")
}

enum TipoRegistro {
  SIEMBRA
  RIEGO
  FERTILIZACION
  PODA
  TRATAMIENTO_PLAGAS
  COSECHA
  OBSERVACION
  INSPECCION
  ALERTA
}

// ─── EXPENSES / GASTOS ────────────────────────────────────────────────────────

model Gasto {
  id         String        @id @default(cuid())
  cultivoId  String?
  cultivo    Cultivo?      @relation(fields: [cultivoId], references: [id])
  concepto   String
  categoria  CategoriaGasto
  monto      Float
  fecha      DateTime      @default(now())
  proveedor  String?
  factura    String?
  notas      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("gastos")
}

// ─── LABOR / JORNALES ─────────────────────────────────────────────────────────
// Registro de mano de obra — mayor costo operativo en el campo colombiano.
// Se relaciona con finanzas como gasto automático categoría MANO_OBRA.

model Jornal {
  id              String    @id @default(cuid())
  cultivoId       String?
  cultivo         Cultivo?  @relation(fields: [cultivoId], references: [id])
  loteId          String?
  lote            Lote?     @relation(fields: [loteId], references: [id])
  fecha           DateTime  @default(now())
  operario        String                      // Nombre del trabajador
  horasTrabajadas Float     @default(8)       // Horas del jornal (default: día completo)
  valorDia        Float                       // Tarifa día completa en COP (ej: $50.000)
  actividad       String                      // "Fumigada", "Abonada", "Limpia", "Riego manual"
  descripcion     String?                     // Detalles adicionales
  imagen          String?   @db.Text          // Base64 data URL or external URL
  loteArea        String?                     // Si aplica a un área específica del lote
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("jornales")
}

enum CategoriaGasto {
  INSUMOS
  MANO_OBRA
  MAQUINARIA
  AGUA_RIEGO
  TRANSPORTE
  CERTIFICACIONES
  TIERRA
  SEMILLAS_PLANTULAS
  HERRAMIENTAS
  ENERGIA
  OTROS
}

// ─── INCOME / INGRESOS ────────────────────────────────────────────────────────

model Ingreso {
  id          String    @id @default(cuid())
  cultivoId   String?
  cultivo     Cultivo?  @relation(fields: [cultivoId], references: [id])
  compradorId String?
  comprador   Comprador? @relation(fields: [compradorId], references: [id])
  concepto    String
  monto       Float
  cantidadKg  Float?
  precioKg    Float?
  fecha       DateTime  @default(now())
  notas       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ingresos")
}

// ─── BUYERS / COMPRADORES ─────────────────────────────────────────────────────

model Comprador {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre       String
  tipo         TipoComprador
  ciudad       String
  departamento String?
  contacto     String?
  email        String?
  telefono     String?
  capacidadTon Float?
  precioKg     Float?
  notas        String?
  estado       String        @default("ACTIVO")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  ingresos     Ingreso[]

  @@map("compradores")
}

enum TipoComprador {
  COOPERATIVA
  EXPORTADOR
  MAYORISTA
  SUPERMERCADO
  PLAZA_MERCADO
  RESTAURANTE
  OTRO
}

// ─── WEATHER ALERTS / ALERTAS CLIMÁTICAS ─────────────────────────────────────

model AlertaClimatica {
  id          String     @id @default(cuid())
  tipo        TipoAlerta
  titulo      String
  descripcion String
  severidad   Severidad  @default(MEDIA)
  fechaInicio DateTime
  fechaFin    DateTime?
  activa      Boolean    @default(true)
  leida       Boolean    @default(false)
  datos       Json?
  municipio   String?
  createdAt   DateTime   @default(now())

  @@map("alertas_climaticas")
}

enum TipoAlerta {
  HELADA
  LLUVIA_EXCESIVA
  SEQUIA
  VIENTO_FUERTE
  TEMPERATURA_ALTA
  GRANIZO
  PLAGA
  OTRO
}

enum Severidad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

// ─── AI CHAT / HISTORIAL IA ───────────────────────────────────────────────────

model ChatMessage {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String      @db.Text
  tokens    Int?
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─── USER PREFERENCES ─────────────────────────────────────────────────────────

model UserPreferences {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tempMinAlert Float    @default(12)
  tempMaxAlert Float    @default(32)
  rainAlertMm  Float    @default(30)
  windAlertKmh Float    @default(40)
  droughtDays  Int      @default(5)

  lat          Float    @default(7.9273)
  lng          Float    @default(-72.5078)
  municipio    String   @default("Norte de Santander")

  emailAlerts  Boolean  @default(true)
  pushAlerts   Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("user_preferences")
}
